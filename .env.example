# OpenAI-compatible endpoint. It can point to OpenAI, DeepSeek, Qwen, or any
# service that implements /v1/chat/completions and /v1/embeddings.
AGENT_HARNESS_BASE_URL=https://api.openai.com/v1
AGENT_HARNESS_API_KEY=replace-me
AGENT_HARNESS_CHAT_MODEL=gpt-4o-mini
AGENT_HARNESS_EMBEDDING_MODEL=text-embedding-3-small

# DeepSeek example:
# DeepSeek supports OpenAI-compatible chat. For this project, use local-hash
# embeddings unless you configure a separate embedding provider in code.
# AGENT_HARNESS_BASE_URL=https://api.deepseek.com
# AGENT_HARNESS_API_KEY=sk-your-deepseek-key
# AGENT_HARNESS_CHAT_MODEL=deepseek-v4-flash
# AGENT_HARNESS_EMBEDDING_MODEL=local-hash
